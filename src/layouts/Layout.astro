---
import { Image } from 'astro:assets';
import profilePic from '../assets/profile_pic.png';
import '../styles/style.css';
import '@fontsource-variable/montserrat';
import '@fontsource/merriweather';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Dan Lafeir's personal site — projects, playbook, and resume." } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'About' },
  { href: '/playbook/', label: 'Playbook' },
  { href: '/projects/', label: 'Projects' },
  { href: '/resume/', label: 'Resume' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href.slice(0, -1));
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Dan Lafeir</title>
    <link rel="icon" type="image/png" href="/images/icon.png" />
  </head>
  <body>
    <div class="site-wrapper">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-topbar">
          <div class="sidebar-profile">
            <Image
              class="sidebar-avatar"
              src={profilePic}
              width={100}
              height={100}
              alt="Dan Lafeir"
            />
            <p class="sidebar-name">Dan Lafeir</p>
            <p class="sidebar-tagline">Builder, Leader, Adaptable</p>
          </div>

          <button
            class="mobile-menu-toggle"
            id="menu-toggle"
            aria-label="Open menu"
            aria-expanded="false"
          >
            <svg class="icon-hamburger" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect y="4" width="22" height="2" rx="1" fill="currentColor"/>
              <rect y="10" width="22" height="2" rx="1" fill="currentColor"/>
              <rect y="16" width="22" height="2" rx="1" fill="currentColor"/>
            </svg>
            <svg class="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <line x1="3" y1="3" x2="19" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="19" y1="3" x2="3" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="sidebar-collapsible">
          <nav>
            <ul class="sidebar-nav">
              {navLinks.map(({ href, label, external }) => (
                <li>
                  <a
                    href={href}
                    class={!external && isActive(href) ? 'active' : ''}
                    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >{label}</a>
                </li>
              ))}
            </ul>
          </nav>

          <div class="sidebar-social">
            <a href="https://github.com/danlafeir" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg class="social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              GitHub
            </a>
            <a href="https://linkedin.com/in/danlafeir" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg class="social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </aside>

      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');

      toggle?.addEventListener('click', () => {
        const isOpen = sidebar?.classList.toggle('menu-open');
        toggle.setAttribute('aria-expanded', String(isOpen));
        toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      });
    </script>
  </body>
</html>
