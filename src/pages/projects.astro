---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'projects');
const { title, subtitle, projects } = entry!.data as any;
---

<Layout title={title}>
  <div class="page-header">
    <h1 class="page-title">{title}</h1>
    <p class="page-subtitle">{subtitle}</p>
  </div>

  <div class="projects-grid">
    {projects.map((project: any) => (
      <a href={project.url} class="project-card" target="_blank" rel="noopener noreferrer">
        <div class="project-card-header">
          <svg class="social-icon" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" style="color: var(--color-primary); fill: currentColor;">
            <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"/>
          </svg>
          <h2 class="project-name">{project.name}</h2>
        </div>
        <p class="project-desc">{project.description}</p>
        {project.topics?.length > 0 && (
          <div class="project-topics">
            {project.topics.map((topic: string) => (
              <span class="project-topic">{topic}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <a href="https://github.com/danlafeir" class="github-profile-link" target="_blank" rel="noopener noreferrer">
    View all on GitHub →
  </a>
</Layout>
